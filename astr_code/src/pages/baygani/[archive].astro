---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    const archivesMap = new Map();
    
    allPosts.forEach(post => {
        let archiveLabel = "نامشخص";
        if (post.data.jalaliDate) {
            // Extracts "Month Year" (e.g., "مرداد ۱۴۰۲") from "12 مرداد 1402"
            const parts = post.data.jalaliDate.split(" ");
            if (parts.length >= 3) {
                archiveLabel = `${parts[1]} ${parts[2]}`; 
            }
        }

        if (!archivesMap.has(archiveLabel)) {
            archivesMap.set(archiveLabel, []);
        }
        archivesMap.get(archiveLabel).push(post);
    });

    return Array.from(archivesMap.entries()).map(([archive, posts]) => {
        // Safely sort posts chronologically
        posts.sort((a, b) => {
            const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
            const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
            return dateB - dateA;
        });
        return {
            params: { archive },
            props: { posts, allPosts }
        };
    });
}

const { archive } = Astro.params;
const { posts, allPosts } = Astro.props;

// Rebuild sidebar data for the sub-page
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    const pTitle = post.data.title || "—";
    const pTags = post.data.tags ? [...post.data.tags] : [];
    if (pTitle === "—" && !pTags.includes("سیاه‌مشق")) {
        pTags.push("سیاه‌مشق");
    }

    pTags.forEach(t => {
        tagCounts[t] = (tagCounts[t] || 0) + 1;
    });

    let archLabel = "نامشخص";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archLabel] = (archiveCounts[archLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => b.count - a.count);

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    const imgRegex = /<img[^>]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>بدون محتوا</p>";
    let text = markdownBody.replace(/!\[.*?\]\(.*?\)/g, '').replace(/<img[^>]*>/g, '');
    const paragraphs = text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p.length > 0);
    let excerptHtml = "";
    let currentLen = 0;
    
    for (let p of paragraphs) {
        p = p.replace(/\n/g, '<br>');
        p = p.replace(/^#+\s+/g, '');
        p = p.replace(/(\*\*|__)(.*?)\1/g, '$2');
        p = p.replace(/(\*|_)(.*?)\1/g, '$2');
        
        excerptHtml += `<p>${p}</p>`;
        currentLen += p.length;
        if (currentLen >= 350) break;
    }
    return excerptHtml || "<p>بدون محتوا</p>";
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بایگانی: {archive} | دلشرم</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <a href="/delsharm" style="float: right; font-weight: bold;">← بازگشت</a>
            <h1><a href="/delsharm" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">محمدصادق رسولی</p>
            <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 20px 0;">
            <h2 style="margin: 0; font-size: 1.5em; text-align: center;">بایگانی نوشته‌ها: {archive}</h2>
            <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; text-align: center;">{toFa(posts.length)} نوشته یافت شد</p>
        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="posts-grid">
                    
                    {posts.map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content">
                                <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
                                
                                {post.data.jalaliDate && (
                                    <div class="date">{post.data.jalaliDate}</div>
                                )}
                                
                                <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                
                                <a href={`/blog/${post.id}/`} class="read-more">ادامه مطلب ←</a>
                            </div>
                        </div>
                    ))}
                    
                </div>
            </div>

            <div class="sidebar-area">
                <div class="section-title">موضوعات پرطرفدار</div>
                <div class="tags-grid">
                    {sortedTags.map(([t, count]) => (
                        <a href={`/tags/${t}/`} class="tag-tile">
                            <span class="tag-name">{t}</span>
                            <span class="tag-count">{toFa(count)}</span>
                        </a>
                    ))}
                </div>
                
                <div class="section-title">بایگانی ماهانه</div>
                <div class="tags-grid">
                    {sortedArchives.map(arch => (
                        <a href={`/baygani/${arch.label}/`} class="baygani-tile">
                            <span class="tag-name">{arch.label}</span>
                            <span class="tag-count">{toFa(arch.count)}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>