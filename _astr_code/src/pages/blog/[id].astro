---
// 1. We must import the standalone `render` function here now
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    return allPosts.map(post => ({
        params: { id: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;

// 2. We use the standalone render function instead of post.render()
const { Content } = await render(post);

const title = post.data.title || "—";
const jalaliDate = post.data.jalaliDate;

// Apply your blank-title rule to this specific post's tags
let tags = post.data.tags ? [...post.data.tags] : [];
if (title === "—" && !tags.includes("سیاه‌مشق")) {
    tags.push("سیاه‌مشق");
}

// 3. Fetch all posts to generate the footer tags/archives grids
const allPosts = await getCollection('blog');
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(p => {
    const pTitle = p.data.title || "—";
    const pTags = p.data.tags ? [...p.data.tags] : [];
    
    if (pTitle === "—" && !pTags.includes("سیاه‌مشق")) {
        pTags.push("سیاه‌مشق");
    }

    pTags.forEach(tag => {
        tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
    
    let archiveLabel = "نامشخص";
    if (p.data.jalaliDate) {
        const parts = p.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archiveLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archiveLabel] = (archiveCounts[archiveLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => b.count - a.count);

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | دلشرم</title>
    
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="single-post-container">
        <div class="page-header" style="margin-bottom: 30px;">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">محمدصادق رسولی</p>
        </div>
        
        <a href="/delsharm/" style="display: inline-block; margin-bottom: 20px; font-weight: bold;">← بازگشت به صفحه اصلی</a>
        
        <h2 style="border-bottom: 2px solid var(--border-color); padding-bottom: 15px; margin-top: 10px;">{title}</h2>
        
        {jalaliDate && (
            <div class="date" style="color: var(--text-muted); font-size: 0.9em; margin-bottom: 20px;">
                {jalaliDate}
            </div>
        )}
        
        <div class="post-content-body">
            {/* Renders the markdown content */}
            <Content />
        </div>
        
        {tags && tags.length > 0 && (
            <div class="post-tags">
                <strong>برچسب‌ها:</strong>
                {tags.map((tag: string, index: number) => (
                    <>
                        <a href={`/delsharm/tags/${tag}/`} style="color: #2980b9;">{tag}</a>
                        {index < tags.length - 1 && <span>،</span>}
                    </>
                ))}
            </div>
        )}
        
        <div id="comments-section" style="margin-top: 50px; padding-top: 20px; border-top: 2px solid var(--border-color);">
            <h3 style="color: var(--text-heading);">نظرات</h3>
            <p style="color: var(--text-muted);">بخش نظرات به‌زودی فعال می‌شود...</p>
        </div>
        
        <div class="subpage-footer" style="margin-top: 80px; padding-top: 40px; border-top: 2px solid var(--border-color);">
            <h3 style="color: var(--text-heading); margin-bottom: 20px; font-size: 1.3em;">موضوعات پرطرفدار</h3>
            <div class="tags-grid">
                {sortedTags.map(([t, count]) => (
                    <a href={`/delsharm/tags/${t}/`} class="tag-tile">
                        <span class="tag-name">{t}</span>
                        <span class="tag-count">{toFa(count)}</span>
                    </a>
                ))}
            </div>
            <h3 style="color: var(--text-heading); margin-top: 40px; margin-bottom: 20px; font-size: 1.3em;">بایگانی ماهانه</h3>
            <div class="tags-grid">
                {sortedArchives.map(arch => (
                    <a href={`/delsharm/baygani/${arch.label}/`} class="baygani-tile">
                        <span class="tag-name">{arch.label}</span>
                        <span class="tag-count">{toFa(arch.count)}</span>
                    </a>
                ))}
            </div>
        </div>
        
    </div>

    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        
        updateIcon();
        
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>