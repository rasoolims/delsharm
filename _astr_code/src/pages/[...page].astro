---
import { getCollection } from 'astro:content';
// Make sure this path points to your global.css correctly! 
// Use '../styles/global.css' if this file is in src/pages/
// Use '../../styles/global.css' if this file is in src/pages/blog/
import '../styles/global.css';

export async function getStaticPaths({ paginate }) {
    const rawPosts = await getCollection('blog');
    
    // Ultra-safe sort: handles missing or broken dates without crashing
    const sortedPosts = rawPosts.sort((a, b) => {
        const dateA = (a.data && a.data.date) ? new Date(a.data.date).getTime() : 0;
        const dateB = (b.data && b.data.date) ? new Date(b.data.date).getTime() : 0;
        return dateB - dateA;
    });
    
    return paginate(sortedPosts, { pageSize: 12 });
}

const { page } = Astro.props;
const allPosts = await getCollection('blog');

const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    const title = post.data.title || "—";
    const tags = post.data.tags ? [...post.data.tags] : [];
    
    if (title === "—" && !tags.includes("سیاه‌مشق")) {
        tags.push("سیاه‌مشق");
    }

    tags.forEach(tag => {
        tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });

    let archiveLabel = "نامشخص";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archiveLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archiveLabel] = (archiveCounts[archiveLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => b.count - a.count);

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    const imgRegex = /<img[^>]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>بدون محتوا</p>";
    let text = markdownBody.replace(/!\[.*?\]\(.*?\)/g, '').replace(/<img[^>]*>/g, '');
    const paragraphs = text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p.length > 0);
    let excerptHtml = "";
    let currentLen = 0;
    
    for (let p of paragraphs) {
        p = p.replace(/\n/g, '<br>');
        p = p.replace(/^#+\s+/g, '');
        p = p.replace(/(\*\*|__)(.*?)\1/g, '$2');
        p = p.replace(/(\*|_)(.*?)\1/g, '$2');
        
        excerptHtml += `<p>${p}</p>`;
        currentLen += p.length;
        if (currentLen >= 350) break;
    }
    return excerptHtml || "<p>بدون محتوا</p>";
}

const totalPages = page.lastPage;
const currentPage = page.currentPage;
const pageNumbers = [];
let lastAdded = 0;

for(let i = 1; i <= totalPages; i++) {
    if (i <= 5 || i > totalPages - 3 || Math.abs(i - currentPage) <= 1) {
        if (lastAdded > 0 && i - lastAdded > 1) {
            pageNumbers.push('...');
        }
        pageNumbers.push(i);
        lastAdded = i;
    }
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>دلشرم {currentPage > 1 ? `- صفحه ${toFa(currentPage)}` : ''}</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">محمدصادق رسولی</p>
        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="section-title" style="margin-top: 0;">آخرین نوشته‌ها</div>
                <div class="posts-grid">
                    
                    {/* Notice this uses page.data.map, NOT posts.map! */}
                    {page.data.map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content">
                                <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                
                                {post.data.jalaliDate && (
                                    <div class="date">{post.data.jalaliDate}</div>
                                )}
                                
                                <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                
                                <a href={`/delsharm/blog/${post.id}/`} class="read-more">ادامه مطلب ←</a>
                            </div>
                        </div>
                    ))}
                    
                </div>

                {totalPages > 1 && (
                    <div class="pagination">
                        {page.url.prev ? <a href={page.url.prev}>→ جدیدتر</a> : <span></span>}
                        
                        <div class="page-numbers">
                            {pageNumbers.map(num => {
                                if (num === '...') return <span>...</span>;
                                if (num === currentPage) return <span class="current-page">{toFa(num as number)}</span>;
                                
                                const link = num === 1 ? '/delsharm/' : `/delsharm/${num}`;
                                return <a href={link}>{toFa(num as number)}</a>;
                            })}
                        </div>

                        {page.url.next ? <a href={page.url.next}>قدیمی‌تر ←</a> : <span></span>}
                    </div>
                )}
            </div>

            <div class="sidebar-area">
                <div class="section-title">موضوعات پرطرفدار</div>
                <div class="tags-grid">
                    {sortedTags.map(([tag, count]) => (
                        <a href={`/delsharm/tags/${tag}/`} class="tag-tile">
                            <span class="tag-name">{tag}</span>
                            <span class="tag-count">{toFa(count)}</span>
                        </a>
                    ))}
                </div>
                
                <div class="section-title">بایگانی ماهانه</div>
                <div class="tags-grid">
                    {sortedArchives.map(archive => (
                        <a href={`/delsharm/baygani/${archive.label}/`} class="baygani-tile">
                            <span class="tag-name">{archive.label}</span>
                            <span class="tag-count">{toFa(archive.count)}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>